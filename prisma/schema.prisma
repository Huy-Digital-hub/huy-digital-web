// Prisma Schema für Huy Digital Trading Intelligence Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Benutzer {
  id              String    @id @default(cuid())
  email           String    @unique
  emailVerifiziert DateTime?
  passwortHash    String
  name            String?
  rolle           String    @default("benutzer")
  erstelltAm      DateTime  @default(now())
  aktualisiertAm  DateTime  @updatedAt
}

model PasswortResetToken {
  id         String    @id @default(cuid())
  token      String    @unique
  email      String
  ablauftAm  DateTime
  benutztAm  DateTime?
  erstelltAm DateTime  @default(now())

  @@index([email])
  @@index([token])
}
